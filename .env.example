VITE_ENABLE_DASHBOARD=true
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_FOLDER=ryze

# ── Vite dev proxy ────────────────────────────────────────────────────────────
# Where /api/* requests are forwarded during local development.
# Leave empty (or omit) to use the local backend in server/ on :8000.
# Set to https://ryzeeducation.com.au to route to the production backend.
API_PROXY_TARGET=http://localhost:8000

# ── Frontend auth ─────────────────────────────────────────────────────────────
# Set to true to skip all real auth and use hardcoded mock users.
# Useful for UI-only development when the backend is not running.
VITE_MOCK_AUTH=false

# ── Legacy / bot API (only needed if using the old ryze-discord-bot backend) ──
VITE_PORTAL_API_URL=
VITE_PORTAL_API_KEY=

# ── AI features (client-side keys — scope to your domain) ────────────────────
VITE_DEEPSEEK_API_KEY=
VITE_MOONSHOT_API_KEY=
