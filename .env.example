VITE_ENABLE_DASHBOARD=false
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_FOLDER=ryze

# Dashboard API (bot FastAPI backend)
# URL of the running bot API server (uvicorn bot.api.app:app --port 8000)
VITE_PORTAL_API_URL=http://localhost:8000
# Must match DASHBOARD_API_KEY set on the bot server
VITE_PORTAL_API_KEY=

# AI Arena / Ingestion Studio (Ryze AI features)
# ⚠️  These are client-side keys — scope them to your domain in each provider's dashboard
VITE_DEEPSEEK_API_KEY=
VITE_MOONSHOT_API_KEY=
