VITE_ENABLE_DASHBOARD=true
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_FOLDER=ryze

# ── Backend API URL ───────────────────────────────────────────────────────────
# REQUIRED IN PRODUCTION: absolute URL of the Render (or other) backend.
# All portal API calls go to this URL with credentials: 'include'.
# Leave empty in local dev — the Vite proxy below handles /api/* forwarding.
# In Vercel: set VITE_PORTAL_API_URL=https://ryze-portal-api.onrender.com
VITE_PORTAL_API_URL=

# ── Vite dev proxy ────────────────────────────────────────────────────────────
# Where /api/* requests are forwarded during local development.
# Leave empty (or omit) to use the local backend in server/ on :8000.
# Set to https://ryzeeducation.com.au to route to the production backend.
API_PROXY_TARGET=http://localhost:8000

# ── Auth is cookie-based — no frontend token storage needed ──────────────────
# The backend issues httpOnly cookies (ryze_token / ryze_refresh).
# Dev stubs: use code=dev_admin / dev_tutor / dev_student in Discord callback.
# VITE_MOCK_AUTH has been removed — use the backend dev stubs instead.

# ── AI features (client-side keys — scope to your domain) ────────────────────
VITE_DEEPSEEK_API_KEY=
VITE_MOONSHOT_API_KEY=
