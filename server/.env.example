# ── Database ──────────────────────────────────────────────────────────────────
# For Supabase: find under Settings → Database → Connection string (Transaction mode)
DATABASE_URL=postgresql://user:password@localhost:5432/ryze_education
# For Supabase with pgBouncer use the above; for direct migrations use:
DATABASE_DIRECT_URL=postgresql://user:password@localhost:5432/ryze_education

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_in_production_use_a_long_random_string
# Optional: override token TTLs (default: 15m access, 30d refresh)
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL=30d

# ── Discord OAuth ─────────────────────────────────────────────────────────────
# Required for Discord login (admin/tutor/student). Create app at discord.com/developers
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# ── SMTP (optional — parent invite emails) ───────────────────────────────────
# If not set, invite emails are silently skipped (admin must manually share link)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ryzeeducation.com.au

# ── Cloudinary (optional — file upload) ──────────────────────────────────────
# If not set, POST /api/upload/sign returns 501. URL passthrough still works.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=ryze_uploads

# ── Discord Bot (optional) ────────────────────────────────────────────────────
# Static API key for the Discord bot to call /api/bot/* routes.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BOT_API_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
PORT=8000
# In production: set to your exact frontend origin (e.g. https://portal.ryzeeducation.com.au)
CORS_ORIGIN=http://localhost:3000
# Used to generate parent invite links in emails
PORTAL_BASE_URL=http://localhost:3000
NODE_ENV=development
