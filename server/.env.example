# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ryze_education
DATABASE_DIRECT_URL=postgresql://user:password@localhost:5432/ryze_education

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_use_a_long_random_string

# ── Discord OAuth ─────────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# ── SMTP (optional — invite emails) ───────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ryzeeducation.com.au

# ── App ───────────────────────────────────────────────────────────────────────
PORT=8000
CORS_ORIGIN=http://localhost:3000
PORTAL_BASE_URL=http://localhost:3000
NODE_ENV=development
