PORT=8000
DATABASE_URL="file:./ryze-portal.db"
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=7d
PORTAL_BASE_URL=http://localhost:3000

# Email (optional — if not set, invite links are logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Ryze Education" <noreply@ryzeeducation.com.au>

# Discord OAuth (optional — if not set, only dev stub codes work)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback
